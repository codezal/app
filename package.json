{
  "name": "codezal",
  "version": "0.5.2",
  "private": true,
  "description": "A multi-provider desktop AI workspace built with Tauri, React, and TypeScript.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/codezal/app.git"
  },
  "bugs": {
    "url": "https://github.com/codezal/app/issues"
  },
  "homepage": "https://github.com/codezal/app#readme",
  "scripts": {
    "predev": "node scripts/copy-file-icons.mjs && npm run build:agent-runtime",
    "dev": "vite",
    "prebuild": "node scripts/copy-file-icons.mjs",
    "build": "npm run build:agent-runtime && tsc -b && vite build",
    "build:agent-runtime": "node scripts/build-agent-runtime.mjs",
    "check:agent-runtime": "tsc --noEmit -p tsconfig.agent-runtime.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "tauri": "tauri",
    "dev:llm": "npm run tauri -- dev -f llm-metal",
    "dev:mlx": "npm run tauri -- dev -f llm-metal,llm-mlx",
    "bump": "node scripts/bump-version.mjs",
    "schema": "UPDATE_SCHEMA=1 vitest run tests/settings-schema.test.ts",
    "snapshot:catalog": "node scripts/snapshot-catalog.mjs",
    "dmg": "node scripts/make-dmg.mjs",
    "release:verify": "node scripts/verify-release.mjs",
    "build:mac:arm": "npm run tauri -- build --bundles app --target aarch64-apple-darwin --features llm-metal,llm-mlx && node scripts/make-dmg.mjs aarch64-apple-darwin",
    "build:mac:intel": "npm run tauri -- build --bundles app --target x86_64-apple-darwin --features llm-metal && node scripts/make-dmg.mjs x86_64-apple-darwin",
    "build:win": "npm run tauri -- build --target x86_64-pc-windows-msvc --features llm-vulkan --bundles nsis",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.110",
    "@ai-sdk/anthropic": "^3.0.79",
    "@ai-sdk/azure": "^3.0.67",
    "@ai-sdk/cerebras": "^2.0.54",
    "@ai-sdk/cohere": "^3.0.36",
    "@ai-sdk/deepinfra": "^2.0.52",
    "@ai-sdk/deepseek": "^2.0.35",
    "@ai-sdk/google": "^3.0.79",
    "@ai-sdk/google-vertex": "^4.0.139",
    "@ai-sdk/groq": "^3.0.39",
    "@ai-sdk/mistral": "^3.0.37",
    "@ai-sdk/openai": "^3.0.65",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@ai-sdk/perplexity": "^3.0.33",
    "@ai-sdk/togetherai": "^2.0.53",
    "@ai-sdk/vercel": "^2.0.50",
    "@ai-sdk/xai": "^3.0.92",
    "@anthropic-ai/claude-agent-sdk": "^0.3.202",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@fabianlars/tauri-plugin-oauth": "^2.0.0",
    "@lezer/highlight": "^1.2.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.2",
    "@tauri-apps/plugin-notification": "^2.3.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "ai": "^6.0.191",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "fflate": "^0.8.3",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "lucide-react": "^1.17.0",
    "material-icon-theme": "^5.35.0",
    "mermaid": "^11.15.0",
    "monaco-editor": "^0.55.1",
    "pdfjs-dist": "^6.0.227",
    "pnpm": "^11.5.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remend": "^1.3.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings 0"
    ]
  },
  "overrides": {
    "dompurify": "3.4.11"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "macos-alias",
      "fs-xattr"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-strip": "^3.0.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  },
  "optionalDependencies": {
    "appdmg": "^0.6.6"
  }
}
