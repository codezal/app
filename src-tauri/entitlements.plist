<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- The bundled Bun runtime uses JavaScriptCore JIT.
         Hardened runtime requires JIT and writable-executable memory
         entitlements; without them Bun-backed LSP servers crash in notarized
         builds. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Bun and helper binaries/native modules from node_modules may be signed
         differently, so library validation must be disabled for hardened
         runtime builds. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
