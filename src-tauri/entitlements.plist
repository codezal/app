<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Native helpers (MLX dylib loaded via libloading, local inference)
         load third-party libraries at runtime that are signed differently,
         so library validation must be disabled for hardened runtime builds. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- JIT + writable-executable memory retained for runtime helpers. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
</dict>
</plist>
