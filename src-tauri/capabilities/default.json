{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Codezal default izinleri",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-destroy",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-start-resize-dragging",
    "core:window:allow-close",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:webview:allow-set-webview-zoom",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "os:default",
    "os:allow-platform",
    "os:allow-arch",
    "os:allow-locale",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "opener:allow-open-url",
    "dialog:default",
    "dialog:allow-confirm",
    "fs:default",
    "fs:allow-app-read",
    "fs:allow-app-write",
    "fs:allow-app-write-recursive",
    "fs:allow-app-meta",
    "fs:allow-app-meta-recursive",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-read-text-file",
    "fs:allow-read-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-watch",
    "fs:allow-unwatch",
    "shell:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    "oauth:allow-start",
    "oauth:allow-cancel",
    "updater:default",
    "process:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "notification:default",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://**" },
        { "url": "http://localhost:*/**" },
        { "url": "http://127.0.0.1:*/**" }
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$HOME/**" },
        { "path": "$HOME/**/.*" },
        { "path": "$HOME/**/.*/**" },
        { "path": "$HOME/.*" },
        { "path": "$HOME/.*/**" },
        { "path": "$HOME/.codezal" },
        { "path": "$HOME/.codezal/**" },
        { "path": "$HOME/**/.codezal" },
        { "path": "$HOME/**/.codezal/**" },
        { "path": "$HOME/.agents" },
        { "path": "$HOME/.agents/**" },
        { "path": "$HOME/**/.agents" },
        { "path": "$HOME/**/.agents/**" },
        { "path": "$HOME/.codezal/plugins/*/.codezal-plugin" },
        { "path": "$HOME/.codezal/plugins/*/.codezal-plugin/**" },
        { "path": "$HOME/.codezal/marketplaces/*/plugins-inline/*/.codezal-plugin" },
        { "path": "$HOME/.codezal/marketplaces/*/plugins-inline/*/.codezal-plugin/**" }
      ],
      "deny": [
        { "path": "$HOME/.ssh" },
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/**/.ssh" },
        { "path": "$HOME/**/.ssh/**" },
        { "path": "$HOME/.aws" },
        { "path": "$HOME/.aws/**" },
        { "path": "$HOME/**/.aws" },
        { "path": "$HOME/**/.aws/**" },
        { "path": "$HOME/.gnupg" },
        { "path": "$HOME/.gnupg/**" },
        { "path": "$HOME/**/.gnupg" },
        { "path": "$HOME/**/.gnupg/**" },
        { "path": "$HOME/.kube" },
        { "path": "$HOME/.kube/**" },
        { "path": "$HOME/.docker/config.json" },
        { "path": "$HOME/.git-credentials" },
        { "path": "$HOME/.netrc" },
        { "path": "$HOME/.npmrc" },
        { "path": "$HOME/.pypirc" }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "bash", "cmd": "bash", "args": ["-lc", { "validator": "[\\s\\S]*" }] },
        { "name": "sh", "cmd": "sh", "args": ["-lc", { "validator": "[\\s\\S]*" }] },
        { "name": "cmd", "cmd": "cmd", "args": true },
        { "name": "powershell", "cmd": "powershell", "args": true },
        { "name": "git", "cmd": "git", "args": true },
        { "name": "rg", "cmd": "rg", "args": true },
        { "name": "grep", "cmd": "grep", "args": true },
        { "name": "find", "cmd": "find", "args": true },
        { "name": "node", "cmd": "node", "args": true },
        { "name": "curl", "cmd": "curl", "args": true },
        { "name": "tar", "cmd": "tar", "args": true },
        { "name": "claude", "cmd": "claude", "args": true },
        { "name": "codex", "cmd": "codex", "args": true },
        { "name": "opencode", "cmd": "opencode", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "bash", "cmd": "bash", "args": ["-lc", { "validator": "[\\s\\S]*" }] },
        { "name": "sh", "cmd": "sh", "args": ["-lc", { "validator": "[\\s\\S]*" }] },
        { "name": "cmd", "cmd": "cmd", "args": true },
        { "name": "powershell", "cmd": "powershell", "args": true },
        { "name": "git", "cmd": "git", "args": true },
        { "name": "rg", "cmd": "rg", "args": true },
        { "name": "grep", "cmd": "grep", "args": true },
        { "name": "find", "cmd": "find", "args": true },
        { "name": "node", "cmd": "node", "args": true },
        { "name": "curl", "cmd": "curl", "args": true },
        { "name": "tar", "cmd": "tar", "args": true },
        { "name": "claude", "cmd": "claude", "args": true },
        { "name": "codex", "cmd": "codex", "args": true },
        { "name": "opencode", "cmd": "opencode", "args": true }
      ]
    }
  ]
}
