set -e

npx lint-staged

stashed=0
if ! git diff --quiet || [ -n "$(git ls-files --others --exclude-standard)" ]; then
  git stash push --quiet --keep-index --include-untracked -m "husky pre-commit unstaged changes"
  stashed=1
fi

status=0
npx tsc --noEmit --ignoreDeprecations 5.0 -p tsconfig.app.json || status=$?

if [ "$stashed" -eq 1 ]; then
  # Restore directly; stash pop can conflict with partially staged files.
  git restore --worktree --source='stash@{0}' -- .
  if git rev-parse --verify --quiet 'stash@{0}^3' >/dev/null; then
    git ls-tree -r --name-only 'stash@{0}^3' | while IFS= read -r path; do
      git restore --worktree --source='stash@{0}^3' -- "$path"
    done
  fi
  git stash drop --quiet 'stash@{0}'
fi

exit "$status"
